model EthicsReport {
  id           String  @id @default(cuid())
  type         String
  anonymous    Boolean @default(true)
  name         String?
  email        String?
  phone        String?
  description  String
  priority     String
  status       String  @default("Beklemede")
  source       String? @default("Web Form")
  trackingCode String  @unique

  // Whistleblower info (if not anonymous)
  reporterId   String?
  reporter     User?   @relation("ReportedEthics", fields: [reporterId], references: [id])
  reporterName String? // If external user

  // Investigation info
  assigneeId    String?
  assignee      User?     @relation("AssignedEthics", fields: [assigneeId], references: [id])
  assignedAt    DateTime?
  internalNotes String?

  // SLA Tracking (NEW)
  slaDeadline     DateTime? // Calculated deadline based on priority
  escalationLevel Int       @default(0) // 0=Normal, 1=Eskalasyon, 2=Üst Yönetim
  escalatedAt     DateTime?

  // Investigation Outcome (NEW)
  investigationOutcome String? // Doğrulandı, Reddedildi, Kısmen Doğrulandı, Kanıt Yetersiz
  closingSummary       String? // Closing summary text
  disciplinaryAction   Boolean? // Was disciplinary action taken
  closedAt             DateTime?
  closedById           String?

  // Conflict of Interest (NEW)
  assigneeConflictDeclared Boolean @default(false) // Müfettiş çıkar çatışması yok beyanı

  // Finding & Audit Connection (NEW)
  linkedFindingId String?
  targetUnitId    String?
  targetUnit      AuditableUnit? @relation("UnitEthics", fields: [targetUnitId], references: [id])

  // Email Integration (NEW)
  emailMessageId            String? // Original email Message-ID for threading
  emailThreadId             String? // Email thread ID
  emailOriginalContent      String? // Original email body for reference
  disciplinaryActionDetails String? // Details of disciplinary action taken

  messages           EthicsMessage[]
  evidences          EthicsEvidence[]
  ipLogs             EthicsIpLog[]
  investigationNotes EthicsInvestigationNote[]
  linkedFindings     Finding[]                 @relation("EthicsToFinding")
  linkedAudits       Audit[]                   @relation("AuditToEthics")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("ethics_report")
}

model EthicsEvidence {
  id         String       @id @default(cuid())
