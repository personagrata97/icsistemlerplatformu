  @@index([rootId, version])
  @@map("ai_document")
}

// Kalıcı Vektör Deposu (RAG)
// SQLite'ta pgvector çalışmadığı için vektörler JSON string olarak saklanır.
// Cosine similarity hesaplaması uygulama seviyesinde yapılır.
model DocumentChunk {
  id         String      @id @default(cuid())
  documentId String?
  text       String
  vector     String      // JSON serialized float array (384-dim for all-MiniLM-L6-v2)
  source     String      // Kaynak dosya adı
  chunkIndex Int         // Dosya içindeki sıra numarası
  category   String?     // Mevzuat / Çalışma Kağıdı / Genel vb.
  created_at DateTime    @default(now())

  document AiDocument? @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([source])
  @@index([category])
  @@map("document_chunk")
}

model DocumentHistory {
  id             String     @id @default(cuid())
  documentId     String
  version        Int
  fileName       String
  fileSize       Int
  mimeType       String
  uploadedBy     String
  uploadedAt     DateTime   @default(now())
