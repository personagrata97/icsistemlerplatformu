generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Musteri {
  musteri_id  String          @id @default(cuid())
  ad_soyad    String
  segment     String
  bolge       String
  sube        String
  tckn        String?         // Şifreli saklanır
  dogumTarihi DateTime?
  uyruk       String?         @default("TR")
  pasaportNo  String?
  vergiNo     String?
  musteriTuru String          @default("GERCEK") // GERCEK | TUZEL
  created_at  DateTime        @default(now())
  sozlesmeler Sozlesme[]
  matches     SanctionMatch[]

  @@map("musteri")
}

model SanctionList {
  id            String           @id @default(cuid())
  kod           String           @unique // MASAK_6415, MASAK_7262, UN, OFAC_SDN, EU, INTERNAL
  ad            String
  kaynakUrl     String?
  sonGuncelleme DateTime?
  kayitSayisi   Int              @default(0)
  aktif         Boolean          @default(true)
  created_at    DateTime         @default(now())
  entities      SanctionEntity[]

  @@map("sanction_list")
}

model SanctionEntity {
  id                 String          @id @default(cuid())
  listId             String
  tur                String          @default("GERCEK") // GERCEK | TUZEL
  adSoyad            String
  normalizedAd       String
  takmaAdlar         String?         // JSON
  dogumTarihi        DateTime?
  uyruk              String?
  kimlikNo           String?
  pasaportNo         String?
  adres              String?         @db.Text
  listeyeGirisTarihi DateTime?
  kararNo            String?
  ham                String?         @db.Text
  created_at         DateTime        @default(now())
  list               SanctionList    @relation(fields: [listId], references: [id], onDelete: Cascade)
  matches            SanctionMatch[]

  @@map("sanction_entity")
}

model SanctionScreening {
  id                 String          @id @default(cuid())
  tetikleyici        String          // YENI_MUSTERI | LISTE_GUNCELLEME | PERIYODIK | MANUEL
  baslangic          DateTime        @default(now())
  bitis              DateTime?
  tarananKayitSayisi Int             @default(0)
  eslesmeSayisi      Int             @default(0)
  calistiran         String
  matches            SanctionMatch[]

  @@map("sanction_screening")
}

model SanctionMatch {
  id          String             @id @default(cuid())
  screeningId String?
  musteriId   String
  entityId    String
  skor        Int
  eslesmeTuru String             // TAM | BULANIK | KIMLIK
  durum       String             @default("ACIK") // ACIK | INCELEMEDE | YANLIS_ESLESME | DOGRULANDI
  karar       String?
  karariVeren String?
  kararTarihi DateTime?
  gerekce     String?            @db.Text
  created_at  DateTime           @default(now())
  screening   SanctionScreening? @relation(fields: [screeningId], references: [id])
  entity      SanctionEntity     @relation(fields: [entityId], references: [id])
  musteri     Musteri            @relation(fields: [musteriId], references: [musteri_id], onDelete: Cascade)

  @@map("sanction_match")
}

model Sozlesme {
  sozlesme_id               String          @id @default(cuid())
  musteri_id                String
  toplam_tutar              Decimal
  vade                      Int
  taksit_tutari             Decimal
  baslangic_tarihi          DateTime
  teslim_tarihi_planlanan   DateTime?
  teslim_tarihi_gerceklesen DateTime?
  durum                     String
  iptal_durumu              Boolean         @default(false)
  iptal_tarihi              DateTime?
  iptal_nedeni              String?
  created_at                DateTime        @default(now())
  odeme_hareketleri         OdemeHareketi[]
  musteri                   Musteri         @relation(fields: [musteri_id], references: [musteri_id])
  teslimatlar               Teslimat[]

  @@map("sozlesme")
}

model OdemeHareketi {
  hareket_id  String   @id @default(cuid())
  sozlesme_id String
  tarih       DateTime
  tutar       Decimal
  tip         String
  gecikme_gun Int      @default(0)
  created_at  DateTime @default(now())
  sozlesme    Sozlesme @relation(fields: [sozlesme_id], references: [sozlesme_id])

  @@map("odeme_hareketi")
}

model Teslimat {
  teslimat_id   String   @id @default(cuid())
  sozlesme_id   String
  teslim_tarihi DateTime
  teslim_tutar  Decimal
  teslim_tipi   String
  created_at    DateTime @default(now())
  sozlesme      Sozlesme @relation(fields: [sozlesme_id], references: [sozlesme_id])

  @@map("teslimat")
}

model LikiditePozisyonu {
  id                         String   @id @default(cuid())
  tarih                      DateTime @unique
  nakit                      Decimal
  likit_varlik               Decimal
  kisa_vadeli_yukumluluk     Decimal
  teslimat_yukumlulugu_30gun Decimal
  created_at                 DateTime @default(now())

  @@map("likidite_pozisyonu")
}

model RiskKpi {
  kpi_kodu   String           @id
  aciklama   String
  birim      String
  created_at DateTime         @default(now())
  ozetler    GunlukRiskOzet[]
  limitler   RiskLimit[]
  uyarilar   Uyari[]

  @@map("risk_kpi")
}

model RiskLimit {
  id            String   @id @default(cuid())
  kpi_kodu      String
  esik_deger    Decimal
  karsilastirma String
  seviye        String
  created_at    DateTime @default(now())
  kpi           RiskKpi  @relation(fields: [kpi_kodu], references: [kpi_kodu])

  @@map("risk_limit")
}

model Senaryo {
  senaryo_kodu String           @id
  ad           String
  parametreler String
  created_at   DateTime         @default(now())
  ozetler      GunlukRiskOzet[]
  uyarilar     Uyari[]

  @@map("senaryo")
}

model GunlukRiskOzet {
  id            String   @id @default(cuid())
  tarih         DateTime
  senaryo_kodu  String
  kpi_kodu      String
  deger         Decimal
  risk_seviyesi String
  created_at    DateTime @default(now())
  kpi           RiskKpi  @relation(fields: [kpi_kodu], references: [kpi_kodu])
  senaryo       Senaryo  @relation(fields: [senaryo_kodu], references: [senaryo_kodu])

  @@unique([tarih, senaryo_kodu, kpi_kodu])
  @@map("gunluk_risk_ozet")
}

model Uyari {
  uyari_id          String   @id @default(cuid())
  tarih             DateTime @default(now())
  kpi_kodu          String
  senaryo_kodu      String
  esik_deger        Decimal
  gerceklesen_deger Decimal
  risk_seviyesi     String
  durum             String
  mesaj             String?
  created_at        DateTime @default(now())
  senaryo           Senaryo  @relation(fields: [senaryo_kodu], references: [senaryo_kodu])
  kpi               RiskKpi  @relation(fields: [kpi_kodu], references: [kpi_kodu])

  @@map("uyari")
}

model LikiditeStresSonucu {
  id            String   @id @default(cuid())
  tarih         DateTime @default(now())
  senaryo_ad    String
  lcr_deger     Decimal
  risk_seviyesi String
  created_at    DateTime @default(now())

  @@map("likidite_stres_sonucu")
}

model Holiday {
  id          String   @id @default(cuid())
  date        DateTime
  name        String
  type        String   @default("Resmi Tatil") // Resmi Tatil, Dini Bayram, Ulusal Bayram
  isRecurring Boolean  @default(false) // Her yıl tekrarlayan mı?
  created_at  DateTime @default(now())

  @@unique([date])
  @@map("holiday")
}

model Audit {
  id                  String                    @id @default(cuid())
  title               String
  type                String
  status              String
  progress            Int                       @default(0)
  startDate           String
  endDate             String?
  team                String?
  supervisor          String?
  supervisorId        String?
  auditCode           String?
  department          String?
  creatorId           String?
  created_at          DateTime                  @default(now())
  updated_at          DateTime                  @updatedAt
  // workpapers          String? // REMOVED: Use AuditWorkpaper instead
  scope               String?
  objective           String?
  methodology         String?
  criteria            String?
  period              String?
  description         String?
  opinion             String?
  riskLevel           String?
  plannedStartDate    DateTime?
  plannedEndDate      DateTime?
  actualStartDate     DateTime?
  actualEndDate       DateTime?
  isDeleted           Boolean                   @default(false)
  deletedAt           DateTime?
  deletedById         String?
  unitId              String?
  processId           String?
  deletionComment     String?
  deletionReason      String?
  isConfidential      Boolean                   @default(false) // KVKK: Gizli soruşturma/denetim
  confidentialityNote String?                                    // Gizlilik gerekçesi
  linkedEthicsReports EthicsReport[]            @relation("AuditToEthics")
  samples             AuditSample[]
  AuditTest           AuditTest[]
  timesheets          AuditTimesheet[]
  workpaperFiles      AuditWorkpaper[]
  findings            Finding[]
  declarations        IndependenceDeclaration[] @relation("AuditDeclarations")
  auditExtensions     AuditExtensionRequest[]
  communications      AuditCommunication[]
  meetings            AuditMeeting[]
  
  // Soruşturma & İnceleme (Investigation) ACFE Alanları
  fraudType           String?
  financialImpact     Decimal?
  currency            String?                   @default("TRY")
  disciplinaryAction  String?
  involvedParties     String?                   // Şüpheliler ve İfade Verenler (JSON formatında saklanacak)

  // İnceleme/Soruşturma Rapor Metinleri (FAZ 3 — localStorage'dan DB'ye taşındı)
  investigationSummary  String?                   // İnceleme özeti (Olaylar ve Savlar)
  investigationFindings String?                   // Bulgular (tespit detayları)
  investigationOpinion  String?                   // Sonuç ve Kanaat

  // Tebliğ ve Kabul Süreci
  acknowledgedAt      DateTime?
  acknowledgedBy      String?

  // Supervisor Relation (Explicit)
  supervisorUser User? @relation("AuditSupervisor", fields: [supervisorId], references: [id])
  deletedBy      User? @relation("DeletedAudits", fields: [deletedById], references: [id])

  // Note: creatorId mapping missing in User model, skipping for now to avoid errors if not defined there.
  // Actually, let's keep it simple and clean. If User model has relation("AuditSupervisor"), we need it here.
  // In User model (line 550): supervisedAudits Audit[] @relation("AuditSupervisor")
  // In User model (line 549): deletedAudits Audit[] @relation("DeletedAudits")
  AuditableUnit   AuditableUnit? @relation(fields: [auditableUnitId], references: [id])
  auditableUnitId String?

  @@index([auditCode])
  @@index([creatorId])
  @@index([unitId])
  @@index([status])
  @@index([isDeleted])
  @@map("audit")
}

model Finding {
  id                          String                @id @default(cuid())
  auditId                     String
  code                        String?               @unique
  title                       String
  risk                        String
  category                    String?
  status                      String
  dueDate                     DateTime?
  description                 String?
  evidence                    String?
  financialImpact             Decimal?
  departmentResponse          String?
  department                  String?
  criteria                    String?
  rootCause                   String?
  recommendation              String?
  actionPlan                  String?
  isAgreed                    Boolean?
  disagreementReason          String?
  closingRemarks              String?
  // reviewNotes                 String? // REMOVED: Use ReviewNote relation
  notes                       ReviewNote[]
  reviewerId                  String?
  verifiedAt                  DateTime?
  verifiedBy                  String?
  assignedUserId              String?
  notificationDate            DateTime?
  responseDate                DateTime?
  created_at                  DateTime              @default(now())
  updated_at                  DateTime              @updatedAt
  lastEditedAt                DateTime?
  isRiskAccepted              Boolean?              @default(false)
  riskAcceptanceJustification String?
  riskAcceptedBy              String?
  riskAcceptedAt              DateTime?
  escalationLevel             Int                   @default(0)
  supervisorId                String?
  processId                   String?
  riskId                      String?
  controlId                   String?
  linkedEthicsReportId        String?
  isRecurring                 Boolean               @default(false)
  recurringFindingId          String?
  recurringNote               String?
  isConfidential              Boolean               @default(false) // KVKK: Gizli bulgu
  confidentialityNote         String?
  isDeleted                   Boolean               @default(false)
  deletedAt                   DateTime?
  deletedById                 String?
  auditTestId                 String?
  workpaperId                 String?
  deletionComment             String?
  deletionReason              String?
  conciliation                AuditConciliation?
  conciliationMessages        ConciliationMessage[]
  followUps                   AuditFollowUp[]
  extensionRequests           ExtensionRequest[]
  auditTest                   AuditTest?            @relation(fields: [auditTestId], references: [id])
  workpaper                   AuditWorkpaper?       @relation(fields: [workpaperId], references: [id])
  audit                       Audit                 @relation(fields: [auditId], references: [id], onDelete: Cascade)
  deletedBy                   User?                 @relation("DeletedFindings", fields: [deletedById], references: [id])
  linkedEthicsReport          EthicsReport?         @relation("EthicsToFinding", fields: [linkedEthicsReportId], references: [id])
  reviewer                    User?                 @relation("FindingReviewer", fields: [reviewerId], references: [id])
  supervisor                  User?                 @relation("FindingSupervisor", fields: [supervisorId], references: [id])
  assignedUser                User?                 @relation("FindingAssignee", fields: [assignedUserId], references: [id])

  @@index([auditId])
  @@index([status])
  @@index([risk])
  @@index([isDeleted])
  @@index([assignedUserId])
  @@map("finding")
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  type        String   @default("info")
  category    String   @default("Genel")
  isRead      Boolean  @default(false)
  link        String?
  createdAt   DateTime @default(now())
  user        User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notification")
}

model AuditLog {
  id         String   @id @default(cuid())
  date       DateTime @default(now())
  user       String
  action     String
  details    String
  targetType String
  targetId   String?
  auditId    String?
  changeData String?
  ipAddress  String?
  previousHash String?
  hash       String?

  @@index([targetType, targetId])
  @@index([auditId])
  @@map("audit_log")
}

model AuditPlan {
  id                 String    @id @default(cuid())
  title              String
  type               String
  quarter            String
  year               Int
  status             String    @default("Planlandı")
  priority           String
  assignedTo         String?
  startDate          String?
  endDate            String?
  approvedBy         String?
  approvedAt         DateTime?
  signedDocumentPath String?
  description        String?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  @@map("audit_plan")
}

model AuditableUnit {
  id                   String              @id @default(cuid())
  name                 String
  code                 String?
  type                 String
  parentId             String?
  riskLevel            String
  description          String?
  manager              String?
  location             String?
  employeeCount        Int?
  transactionVolume    String?
  financialImpact      String?
  riskScore            Int?
  impactScore          Int?                @default(1) // Etki (1-5)
  likelihoodScore      Int?                @default(1) // Olasılık (1-5)
  residualRiskScore    Int?
  auditCycle           Int?
  lastAuditDate        String?
  lastAuditId          String?
  nextAuditDate        String?
  estimatedDays        Int?
  status               String              @default("Aktif")
  notes                String?
  strategicAlignment   String?
  businessCriticality  String?
  regulations          String?
  mandatoryAudit       Boolean?
  lastAuditResult      String?
  openFindingsCount    Int?                @default(0)
  inherentRisk         String?
  controlEffectiveness String?
  changeRisk           Boolean?            @default(false)
  requiredExpertise    String?
  previousAuditDays    Int?
  created_at           DateTime            @default(now())
  updated_at           DateTime            @updatedAt
  audits               Audit[]
  multiYearItems       MultiYearPlanItem[]
  ethicsReports        EthicsReport[]      @relation("UnitEthics")
  processes            Process[]

  @@map("auditable_unit")
}

model Process {
  id          String        @id @default(cuid())
  unitId      String
  name        String
  description String?
  owner       String?
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
  unit        AuditableUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  risks       Risk[]

  @@map("process")
}

model Risk {
  id          String    @id @default(cuid())
  processId   String
  code        String?
  name        String
  description String?
  category    String
  level       String
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  controls    Control[]
  process     Process   @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@map("risk")
}

model Control {
  id          String      @id @default(cuid())
  riskId      String
  code        String?
  name        String
  description String?
  owner       String?
  type        String?
  frequency   String?
  source      String?
  method      String?
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  tests       AuditTest[]
  risk        Risk        @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@map("control")
}

model AuditTest {
  id                     String    @id @default(cuid())
  auditId                String
  controlId              String
  title                  String?
  procedure              String?
  sampleSize             Int?
  designEffectiveness    String?
  operatingEffectiveness String?
  testResult             String?
  testedBy               String?
  testDate               DateTime?
  supervisorId           String?
  supervisorApprovedAt   DateTime?
  // notes                  String? // DELETED: Use ReviewNote relation
  evidence               String?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
  audit                  Audit     @relation(fields: [auditId], references: [id], onDelete: Cascade)
  control                Control   @relation(fields: [controlId], references: [id], onDelete: Cascade)

  findings Finding[]

  // Soft Delete
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  deletedById    String?
  deletionReason String?
  deletedBy      User?     @relation("DeletedTests", fields: [deletedById], references: [id])

  // Approval Fields
  status     String       @default("Taslak") // Taslak, Onay Bekliyor, Onaylandı, Revize İste, Reddedildi
  reviewerId String?
  reviewedAt DateTime?
  // revisionNotes String? // REMOVED: Use ReviewNote relation
  notes      ReviewNote[]
  reviewer   User?        @relation("TestReviewer", fields: [reviewerId], references: [id])
  supervisor User?        @relation("TestSupervisor", fields: [supervisorId], references: [id])

  @@map("audit_test")
}

model AuditEducation {
  id              String   @id @default(cuid())
  title           String
  provider        String
  date            String
  duration        String
  attendees       Int      @default(0)
  status          String   @default("Planlandı")
  description     String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  participantList String?

  @@map("audit_education")
}

model AuditFollowUp {
  id              String    @id @default(cuid())
  findingId       String?
  action          String
  deadline        String
  priority        String
  assignee        String
  status          String    @default("Açık")
  escalationLevel Int       @default(0) // Eskalasyon seviyesi (0 = Yok, 1 = 1. Seviye, 2 = 2. Seviye...)
  lastEscalatedAt DateTime? // Son eskalasyon tarihi
  notes           String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  finding         Finding?  @relation(fields: [findingId], references: [id])

  @@map("audit_follow_up")
}

model AuditConciliation {
  id                 String   @id @default(cuid())
  findingId          String   @unique
  status             String   @default("Bekliyor")
  response           String?
  responseDate       String?
  isAgreed           Boolean?
  disagreementReason String?
  rootCause          String?
  actionPlan         String?
  evidencePath       String?
  digitalSeal        String?
  signedBy           String?
  signedAt           DateTime?
  signedIp           String?
  magicToken         String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  finding            Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@map("audit_conciliation")
}

model ConciliationMessage {
  id           String   @id @default(cuid())
  findingId    String
  senderId     String
  senderName   String
  senderRole   String // e.g. "Auditor", "Department"
  message      String
  isAgreed     Boolean? // if sent by department
  actionPlan   String? // if sent by department
  evidencePath String? // if sent by department
  status       String? // "Submitted", "Rejected", "Approved"
  created_at   DateTime @default(now())

  finding Finding @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@map("conciliation_message")
}

model ExtensionRequest {
  id                String   @id @default(cuid())
  findingId         String
  followUpId        String?
  currentDeadline   String
  requestedDeadline String
  reason            String
  status            String   @default("Beklemede")
  notes             String?
  requestorId       String
  requestorName     String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  finding           Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@map("extension_request")
}

model AuditExtensionRequest {
  id               String    @id @default(cuid())
  auditId          String
  currentEndDate   DateTime
  requestedEndDate DateTime
  reason           String
  notes            String?
  status           String    @default("Beklemede")
  requestedById    String
  reviewedById     String?
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  audit       Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  requestedBy User  @relation("AuditExtRequester", fields: [requestedById], references: [id])
  reviewedBy  User? @relation("AuditExtReviewer", fields: [reviewedById], references: [id])

  @@map("audit_extension_request")
}

model SanctionLog {
  id        String   @id @default(cuid())
  user      String
  category  String
  action    String
  details   String
  timestamp DateTime @default(now())

  @@map("sanction_log")
}

model SanctionScan {
  id         String               @id @default(cuid())
  scanType   String
  scanSource String
  query      String?
  status     String               @default("Tamamlandı")
  user       String
  timestamp  DateTime             @default(now())
  results    SanctionScanResult[]

  @@map("sanction_scan")
}

model SanctionScanResult {
  id          String       @id @default(cuid())
  scanId      String
  matchName   String
  matchSource String
  matchScore  Float
  details     String?
  scan        SanctionScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@map("sanction_scan_result")
}

model SuspiciousTransaction {
  id              String   @id @default(cuid())
  type            String
  customerName    String
  customerId      String?
  transactionType String
  amount          Decimal?
  description     String
  status          String   @default("Beklemede")
  user            String
  trackingCode    String   @unique
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("suspicious_transaction")
}

model User {
  id                  String    @id @default(cuid())
  username            String    @unique
  email               String?
  passwordHash        String?
  displayName         String
  department          String?
  isActive            Boolean   @default(true)
  isDeleted           Boolean   @default(false)
  deletedAt           DateTime?
  deletionReason      String?
  isAdUser            Boolean   @default(false)
  lastLoginAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  certifications      String?
  jobStartDate        String?
  departureDate       String?
  separationReason    String?
  phoneNumber         String?
  registerNumber      String?
  title               String?
  photoUrl            String?
  summary             String?
  skills              String? // JSON string or comma separated
  jobDescription      String?

  deletedAudits      Audit[]                   @relation("DeletedAudits")
  supervisedAudits   Audit[]                   @relation("AuditSupervisor")
  timesheets         AuditTimesheet[]
  workpapersReviewed AuditWorkpaper[]          @relation("WorkpaperReviewer")
  workpapersPrepared AuditWorkpaper[]          @relation("WorkpaperPreparer")
  workpapersLocked   AuditWorkpaper[]          @relation("WorkpaperLocker")
