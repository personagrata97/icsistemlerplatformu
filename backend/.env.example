# ============================================
# İÇ SİSTEMLER PLATFORMU - ORTAM DEĞİŞKENLERİ
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri düzenleyin

# Veritabanı
# SQLite (geliştirme için):
DATABASE_URL="file:./dev.db"
# PostgreSQL (production için):
# DATABASE_URL="postgresql://postgres:password@localhost:5432/icsistemler?schema=public"

# JWT Ayarları
# ÖNEMLİ: Production'da bu değerleri güvenli rastgele stringlerle değiştirin!
JWT_SECRET="icsistemler-jwt-secret-key-degistir-production-da"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Active Directory (Phase 4)
# Şirket IT ekibi tarafından doldurulacak
AD_ENABLED=false
AD_URL="ldap://your-ad-server.domain.com"
AD_BASE_DN="DC=domain,DC=com"
AD_BIND_DN="CN=ServiceAccount,OU=ServiceAccounts,DC=domain,DC=com"
AD_BIND_PASSWORD=""
AD_USER_FILTER="(sAMAccountName={{username}})"
# AD grupları ile uygulama rolleri eşleştirmesi (JSON formatında)
AD_GROUP_MAPPING='{"Domain Admins":"ADMIN","Risk Grubu":"RISK_ADMIN","Denetim Grubu":"AUDIT_ADMIN"}'

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3010"
FRONTEND_URL="http://localhost:3010"

# Şifreleme
# ÖNEMLİ: Production'da 32 karakterlik güvenli rastgele string kullanın!
ENCRYPTION_KEY="degistir-production-da-32-chars!"

# E-posta (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="noreply@example.com"
SMTP_PASS=""

# Etik & Uyum Bildirimleri
ETHICS_COMMITTEE_EMAILS="etik@example.com,uyum@example.com"
ESCALATION_EMAIL="eskalasyon@example.com"
BOARD_EMAIL="yk@example.com"

# Auditron AI Servisi
AUDITRON_ENABLED=false
AUDITRON_AI_URL="http://localhost:11434"
AUDITRON_MODEL="llama3"

# Kurumsal Bilgiler (Raporlarda kullanılır)
ORG_COMPANY_NAME="Emlak Katılım Tasarruf Finansman A.Ş."
ORG_DEPARTMENT_NAME="Teftiş Kurulu Başkanlığı"
ORG_HEAD_TITLE="Teftiş Kurulu Başkanı"
ORG_PLATFORM_NAME="İç Sistemler Platformu"
ORG_CONFIDENTIALITY="GİZLİ"
